#. translators: fixed fee note
#: includes/class-lddfw-driver.php:1947
#, php-format
msgid "The commission was calculated as a fixed fee of %s."
msgstr "Комиссия была рассчитана как фиксированная плата в размере %s."

#. translators: fixed + distance with precise detail
#: includes/class-lddfw-driver.php:2066
#, php-format
msgid ""
"The commission was calculated by adding a fixed fee of %1$s plus a distance "
"of %3$s (shown as %4$s) from the pickup address at %6$s per unit, rounded to "
"%2$s, for a total of %5$s."
msgstr ""
"Комиссия рассчитана путём сложения фиксированной платы %1$s и расстояния "
"%3$s (отображается как %4$s) от адреса получения по %6$s за единицу, "
"округлённого до %2$s, итого %5$s."

#. translators: delivery percentage note
#: includes/class-lddfw-driver.php:1956
#, php-format
msgid ""
"The commission was calculated by applying %1$s%% to the delivery fee of %2$s,"
" resulting in %3$s."
msgstr ""
"Комиссия была рассчитана путём применения %1$s%% к стоимости доставки %2$s, "
"в результате получилось %3$s."

#. translators: order percentage note
#: includes/class-lddfw-driver.php:1967
#, php-format
msgid ""
"The commission was calculated by applying %1$s%% to the net order total ( "
"%2$s − %3$s = %4$s ), resulting in %5$s."
msgstr ""
"Комиссия была рассчитана путём применения %1$s%% к чистой сумме заказа ( "
"%2$s − %3$s = %4$s ), в результате получилось %5$s."

#. translators: combined distance+time note
#: includes/class-lddfw-driver.php:2040
#, php-format
msgid ""
"The commission was calculated using both precise components from the pickup "
"address: %1$s."
msgstr ""
"Комиссия рассчитана с использованием обоих точных компонентов от адреса "
"получения: %1$s."

#. translators: distance precise vs label note
#: includes/class-lddfw-driver.php:1984
#, php-format
msgid ""
"The commission was calculated using the precise distance of %1$s (displayed "
"as %2$s) from the pickup address, at a rate of %3$s per unit (rounded to "
"%4$s)."
msgstr ""
"Комиссия рассчитана с использованием точного расстояния %1$s (отображается "
"как %2$s) от адреса получения по ставке %3$s за единицу (округлено до %4$s)."

#. translators: time precise vs label note
#: includes/class-lddfw-driver.php:2001
#, php-format
msgid ""
"The commission was calculated using the precise duration of %1$s minutes "
"(displayed as %2$s) from the pickup address, at a rate of %3$s per minute "
"(rounded to %4$s)."
msgstr ""
"Комиссия рассчитана с использованием точной продолжительности %1$s мин. "
"(отображается как %2$s) от адреса получения по ставке %3$s в минуту "
"(округлено до %4$s)."

