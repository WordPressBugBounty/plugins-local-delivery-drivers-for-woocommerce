msgid "Add Field"
msgstr "Añadir campo"

msgid "Add Meta Key"
msgstr "Añadir clave meta"

msgid "All items are concatenated with spaces and shown as one line."
msgstr ""
"Todos los elementos se concatenan con espacios y se muestran en una sola "
"línea."

msgid "Are you sure you want to delete this field?"
msgstr "¿Está seguro de que desea eliminar este campo?"

msgid "Array and JSON values"
msgstr "Valores de array y JSON"

