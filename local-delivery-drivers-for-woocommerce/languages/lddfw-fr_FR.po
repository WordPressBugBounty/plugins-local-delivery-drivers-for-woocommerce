msgstr ""
"Non affiché ; seules les valeurs de chaîne de premier niveau sont affichées."

msgid ""
"Optional text placed immediately before the meta value. Example: prefix "
"\"between \" + value \"14:00–18:00\" → driver sees \"Delivery Date: between "
"14:00–18:00\"."
msgstr ""
"Texte optionnel placé immédiatement avant la valeur meta. Exemple : préfixe "
"«entre » + valeur «14:00-18:00» - le livreur voit «Date de livraison : entre "
"14:00-18:00»."

msgid "Optional: add a Value (prefix)"
msgstr "Optionnel : ajouter une valeur (préfixe)"

msgid "Order Card (list screens)"
msgstr "Carte de commande (écrans de liste)"

msgid "Order Detail Page"
msgstr "Page de détail de la commande"

msgid ""
"Preview uses sample text. In the driver panel, fields only appear when the "
"order has a value for the configured meta key."
msgstr ""
"L'aperçu utilise un texte d'exemple. Dans le panneau du livreur, les champs "
"n'apparaissent que lorsque la commande a une valeur pour la clé meta "
"configurée."

msgid "Protected fields (keys starting with _)"
msgstr "Champs protégés (clés commençant par _)"

